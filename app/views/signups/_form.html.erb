<%= form_with(model: signup, class: "contents") do |form| %>
  <% if signup.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(signup.errors.count, "error") %> prohibited this signup from being saved:</h2>

      <ul class="list-disc ml-6">
        <% signup.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :email %>
    <%= form.text_field :email, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": signup.errors[:email].none?, "border-red-400 focus:outline-red-600": signup.errors[:email].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :address %>
    <%= form.text_field :address, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": signup.errors[:address].none?, "border-red-400 focus:outline-red-600": signup.errors[:address].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": signup.errors[:name].none?, "border-red-400 focus:outline-red-600": signup.errors[:name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :current_step %>
    <%= form.number_field :current_step, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": signup.errors[:current_step].none?, "border-red-400 focus:outline-red-600": signup.errors[:current_step].any?}] %>
  </div>

  <div class="my-5 flex items-center gap-2">
    <%= form.label :comms_preference %>
    <%= form.checkbox :comms_preference, class: ["block shadow-sm rounded-md border order-first h-5 w-5", {"border-gray-400 focus:outline-blue-600": signup.errors[:comms_preference].none?, "border-red-400 focus:outline-red-600": signup.errors[:comms_preference].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
