<div>
    <p class="pb-4"> Cool :) and your name? </p>
    <%= form.label :name, "Name:", class: "hidden" %>
    <%= form.text_field :name, required: true, class: ["bg-white block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": form.object.errors[:email].none?, "border-red-400 focus:outline-red-600": form.object.errors[:email].any?}] %>
</div>
